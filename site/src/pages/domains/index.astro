---
import Base from '../../layouts/Base.astro';
import { loadAllDomains } from '../../lib/content';

const domains = loadAllDomains();
---

<Base title="Domain Packs" description="Domain-specific overlays that sharpen agent analysis for your industry">
  <!-- Page Header -->
  <div class="py-16 pb-12">
    <div class="mx-auto max-w-[1200px] px-6">
      <h1 class="text-4xl font-extrabold tracking-tight">Domain Packs</h1>
      <p class="text-[17px] text-[var(--color-text-secondary)] leading-relaxed max-w-[700px] mt-3">
        Domain-specific overlays that sharpen agent analysis for your industry. Each pack injects specialized lexicon, metrics, frameworks, and agent-level heuristic overlays. Activate a domain when creating a deliberation to ground every perspective in your context.
      </p>
    </div>
  </div>

  <!-- Domain Cards -->
  <div class="mx-auto max-w-[1200px] px-6 pb-20">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      {domains.map(domain => (
        <div class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-xl p-6 card-hover">
          <h3 class="text-[17px] font-semibold text-[var(--color-text)]">{domain.name}</h3>
          <p class="text-[15px] text-[var(--color-text-secondary)] leading-relaxed mt-3">
            {domain.description || 'Domain-specific overlay pack'}
          </p>

          <div class="mt-4">
            <span class="badge badge-perspective">{domain.overlayCount} agent overlays</span>
          </div>

          {domain.lexicon.metrics.length > 0 && (
            <div class="mt-5">
              <p class="text-xs font-medium text-[var(--color-text-muted)] uppercase tracking-wider">Key Metrics</p>
              <p class="text-[13px] text-[var(--color-text-muted)] mt-1.5 leading-relaxed">
                {domain.lexicon.metrics.join(', ')}
              </p>
            </div>
          )}

          {domain.lexicon.frameworks.length > 0 && (
            <div class="mt-3">
              <p class="text-xs font-medium text-[var(--color-text-muted)] uppercase tracking-wider">Frameworks</p>
              <p class="text-[13px] text-[var(--color-text-muted)] mt-1.5 leading-relaxed">
                {domain.lexicon.frameworks.join(', ')}
              </p>
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</Base>
