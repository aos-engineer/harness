---
import Base from '../../layouts/Base.astro';
import { loadAllSkills, loadAllAgents } from '../../lib/content';

const skills = loadAllSkills();
const agents = loadAllAgents();
const agentMap = new Map(agents.map(a => [a.id, a]));
---

<Base title="Skills" description="AOS-aware skill definitions that agents can invoke during deliberation or execution">
  <!-- Page Header -->
  <section class="px-6 pt-16 pb-12">
    <div class="mx-auto max-w-[1200px]">
      <h1 class="text-5xl font-extrabold tracking-tight text-[var(--color-text)]">Skills</h1>
      <p class="text-[17px] text-[var(--color-text-secondary)] leading-relaxed max-w-[640px] mt-3">
        AOS-aware skill definitions that agents can invoke during deliberation or execution. Each skill specifies its inputs, outputs, and which agents are qualified to use it.
      </p>
    </div>
  </section>

  <!-- Skill Cards -->
  <section class="px-6 pb-20">
    <div class="mx-auto max-w-[1200px] grid grid-cols-1 md:grid-cols-3 gap-4">
      {skills.map(skill => (
        <div class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-xl p-6 card-hover">
          <h2 class="text-[17px] font-semibold text-[var(--color-text)]">{skill.name}</h2>
          <p class="text-[15px] text-[var(--color-text-secondary)] leading-relaxed mt-2">{skill.description}</p>

          <!-- Required Inputs -->
          {skill.input.required.length > 0 && (
            <div class="mt-5">
              <h3 class="text-xs font-medium text-[var(--color-text-muted)] uppercase tracking-wider mb-2">Required Inputs</h3>
              <div class="flex flex-col gap-1.5">
                {skill.input.required.map((inp: any) => (
                  <div class="flex items-center gap-2 text-[13px]">
                    <span class="dot" style="background: var(--color-border);"></span>
                    <span class="font-semibold text-[var(--color-text)] font-mono">{inp.id}</span>
                    <span class="text-[var(--color-text-muted)]">({inp.type})</span>
                  </div>
                ))}
              </div>
            </div>
          )}

          <!-- Optional Inputs -->
          {skill.input.optional.length > 0 && (
            <div class="mt-3">
              <h3 class="text-xs font-medium text-[var(--color-text-muted)] uppercase tracking-wider mb-2">Optional Inputs</h3>
              <div class="flex flex-col gap-1.5">
                {skill.input.optional.map((inp: any) => (
                  <div class="flex items-center gap-2 text-[13px]">
                    <span class="dot" style="background: var(--color-border);"></span>
                    <span class="font-mono text-[var(--color-text-muted)]">{inp.id}</span>
                    <span class="text-[var(--color-text-muted)]">({inp.type})</span>
                  </div>
                ))}
              </div>
            </div>
          )}

          <!-- Output Artifacts -->
          {skill.output.artifacts.length > 0 && (
            <div class="mt-4">
              <h3 class="text-xs font-medium text-[var(--color-text-muted)] uppercase tracking-wider mb-2">Output Artifacts</h3>
              <div class="flex flex-col gap-1.5">
                {skill.output.artifacts.map((art: any) => (
                  <div class="flex items-center gap-2 text-[13px]">
                    <span class="dot" style="background: var(--color-success);"></span>
                    <span class="font-semibold text-[var(--color-text)] font-mono">{art.id}</span>
                    <span class="badge" style="background: rgba(0,0,0,0.05); color: var(--color-text-muted); font-size: 11px; padding: 1px 7px;">{art.format}</span>
                  </div>
                ))}
              </div>
            </div>
          )}

          <!-- Compatible Agents -->
          {skill.compatible_agents.length > 0 && (
            <div class="pt-4 mt-4 border-t border-[var(--color-border)]">
              <h3 class="text-xs font-medium text-[var(--color-text-muted)] uppercase tracking-wider mb-2">Compatible Agents</h3>
              <div class="flex gap-1.5 flex-wrap">
                {skill.compatible_agents.map((agentId: string) => {
                  const agent = agentMap.get(agentId);
                  return (
                    <a href={`/agents/${agentId}`} class="badge badge-perspective no-underline hover:opacity-80 transition-opacity">
                      {agent?.name ?? agentId}
                    </a>
                  );
                })}
              </div>
            </div>
          )}
        </div>
      ))}
    </div>
  </section>
</Base>
