---
import Base from '../../layouts/Base.astro';
import { loadAllProfiles } from '../../lib/content';

const profiles = loadAllProfiles();

const heroProfiles = profiles.filter(p => ['strategic-council', 'cto-execution'].includes(p.id));
const listProfiles = profiles.filter(p => !['strategic-council', 'cto-execution'].includes(p.id));
---

<Base title="Orchestration Profiles" description="Pre-configured orchestration profiles for strategic deliberation and execution planning">
  <!-- Page Header -->
  <section class="px-6 pt-16 pb-12">
    <div class="mx-auto max-w-[1200px]">
      <h1 class="text-5xl font-extrabold tracking-tight text-[var(--color-text)]">Orchestration Profiles</h1>
      <p class="text-[17px] text-[var(--color-text-secondary)] leading-relaxed max-w-[700px] mt-3">
        {profiles.length} pre-configured agent assemblies for strategic deliberation, execution planning, security review, and more. Each profile defines who participates, how they interact, and what gets produced.
      </p>
      <div class="mt-8 flex gap-2">
        <span class="bg-[var(--color-text)] text-white px-4 py-2 rounded-full text-sm font-medium">All ({profiles.length})</span>
        <span class="bg-[var(--color-surface)] border border-[var(--color-border)] text-[var(--color-text-muted)] px-4 py-2 rounded-full text-sm font-medium">Deliberation ({profiles.filter(p => p.type === 'deliberation').length})</span>
        <span class="bg-[var(--color-surface)] border border-[var(--color-border)] text-[var(--color-text-muted)] px-4 py-2 rounded-full text-sm font-medium">Execution ({profiles.filter(p => p.type === 'execution').length})</span>
      </div>
    </div>
  </section>

  <!-- Hero Cards -->
  <section class="px-6 pb-8">
    <div class="mx-auto max-w-[1200px] grid grid-cols-1 md:grid-cols-2 gap-4">
      {heroProfiles.map(profile => {
        const agentCount = profile.assembly.perspectives.length + 1;
        const tensionCount = profile.delegation.tension_pairs.length;
        const isExecution = profile.type === 'execution';
        const accentColor = isExecution ? 'var(--color-execution)' : 'var(--color-deliberation)';

        return (
          <a href={`/profiles/${profile.id}`} class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-xl p-6 flex gap-4 card-hover no-underline">
            <div class="w-1 rounded-sm flex-shrink-0" style={`background: ${accentColor}`}></div>
            <div class="flex-1">
              <h2 class="text-[17px] font-semibold text-[var(--color-text)]">{profile.name}</h2>
              <p class="text-[15px] text-[var(--color-text-secondary)] leading-relaxed mt-2">{profile.description}</p>
              <div class="mt-3 flex flex-wrap gap-4 text-[13px] text-[var(--color-text-muted)]">
                <span>{agentCount} agents</span>
                <span>{tensionCount} tension pairs</span>
                <span>{profile.constraints.rounds.min}&ndash;{profile.constraints.rounds.max} rounds</span>
                {profile.constraints.budget ? (
                  <span>${profile.constraints.budget.min}&ndash;${profile.constraints.budget.max}</span>
                ) : (
                  <span>{profile.constraints.time.min_minutes}&ndash;{profile.constraints.time.max_minutes} min</span>
                )}
              </div>
              <div class="flex gap-2 mt-3">
                <span class={`badge ${isExecution ? 'badge-execution' : 'badge-deliberation'}`}>{profile.type}</span>
                <span class="badge" style="background: rgba(0,0,0,0.05); color: var(--color-text-muted);">{profile.output.format}</span>
              </div>
            </div>
          </a>
        );
      })}
    </div>
  </section>

  <!-- List Rows -->
  <section class="px-6 pb-20">
    <div class="mx-auto max-w-[1200px]">
      <p class="text-xs font-medium text-[var(--color-text-muted)] uppercase tracking-wider mb-3">More Profiles</p>
      <div class="flex flex-col gap-2">
        {listProfiles.map(profile => {
          const agentCount = profile.assembly.perspectives.length + 1;
          const isExecution = profile.type === 'execution';
          const dotColor = isExecution ? 'var(--color-execution)' : 'var(--color-deliberation)';

          return (
            <a href={`/profiles/${profile.id}`} class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-lg px-4 py-3 flex items-center justify-between card-hover no-underline">
              <div class="flex items-center gap-3">
                <span class="dot" style={`background: ${dotColor}`}></span>
                <span class="text-sm font-semibold text-[var(--color-text)]">{profile.name}</span>
                <span class={`badge ${isExecution ? 'badge-execution' : 'badge-deliberation'}`}>{profile.type}</span>
              </div>
              <div class="flex items-center gap-4 text-xs text-[var(--color-text-muted)]">
                <span>{agentCount} agents</span>
                <span>{profile.constraints.rounds.min}&ndash;{profile.constraints.rounds.max} rounds</span>
                {profile.constraints.budget ? (
                  <span>${profile.constraints.budget.min}&ndash;${profile.constraints.budget.max}</span>
                ) : (
                  <span>{profile.constraints.time.min_minutes}&ndash;{profile.constraints.time.max_minutes} min</span>
                )}
                <span class="text-[var(--color-text-muted)]">&rsaquo;</span>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>
</Base>
