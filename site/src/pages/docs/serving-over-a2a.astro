const sidebarLinks = [
  { id: 'overview', label: 'Overview' },
  { id: 'serve-command', label: 'The serve Command' },
  { id: 'agent-card', label: 'The Agent Card' },
  { id: 'json-rpc', label: 'JSON-RPC Methods' },
  { id: 'skill-routing', label: 'Skill Routing' },
  { id: 'configuration', label: 'Configuration' },
