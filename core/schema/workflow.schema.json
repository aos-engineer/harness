{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "aos/workflow/v1",
  "title": "AOS Workflow Definition",
  "type": "object",
  "required": ["schema", "id", "name", "steps"],
  "properties": {
    "schema": { "const": "aos/workflow/v1" },
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
    "name": { "type": "string" },
    "description": { "type": "string" },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "action"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
          "name": { "type": "string" },
          "action": { "type": "string" },
          "description": { "type": "string" },
          "agents": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Agent IDs to delegate this step to."
          },
          "prompt": {
            "type": "string",
            "description": "The delegation message sent to the agent(s) for this step. Supports template variables."
          },
          "structural_advantage": {
            "type": ["string", "null"],
            "enum": ["speaks-last", null],
            "default": null,
            "description": "Structural advantage for this step. Overrides the agent's profile-level structural_advantage for this step only."
          },
          "input": {
            "type": "array",
            "items": { "type": "string" }
          },
          "output": { "type": "string" },
          "review_gate": { "type": "boolean" }
        },
        "additionalProperties": true
      }
    },
    "gates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["after", "type", "prompt", "on_rejection"],
        "properties": {
          "after": { "type": "string" },
          "type": {
            "enum": ["user-approval", "automated-review"]
          },
          "prompt": { "type": "string" },
          "max_iterations": { "type": "integer", "minimum": 1 },
          "on_rejection": {
            "type": "string",
            "enum": ["re-run-step", "retry_with_feedback"],
            "default": "re-run-step",
            "description": "What to do when the user rejects at this gate."
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": true
}
